# Secrets -- never let these into git history
.env

# Generated at runtime, not source
data/*.jsonl
data/*.txt
data/.gremlin.lock
data/talking.marker
data/.sudo_credential
*.gremlin-backup-*

# Downloaded model weights -- large binaries, not source, and can
# always be re-downloaded via `gremlin models` / `gremlin models --hf`
models/*.gguf

# Standard Python/venv noise
__pycache__/
*.pyc
venv/
.venv/

# android/ is part of this same repo now, tracked alongside the
# desktop files -- only its generated build artifacts are excluded,
# same as the desktop side's own venv/__pycache__ exclusions above.
android/.gradle/
android/**/build/

# llama.cpp checkout -- only used for its convert_hf_to_gguf.py +
# quantize tooling when finetune.py promotes a new fine-tuned GGUF,
# not project source. Re-clonable, not something to track.
tools/llama.cpp/
