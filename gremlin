#!/usr/bin/env bash
# Lets you run `gremlin <command>` instead of `python main.py <command>`.
#
# One-time setup:
#   chmod +x gremlin
#   sudo ln -s "$(pwd)/gremlin" /usr/local/bin/gremlin
# (or add this project directory to your PATH some other way)
#
# After that: `gremlin models`, `gremlin chat gremlin`, etc. work from
# anywhere, and always run against this project's venv + config.

# readlink -f resolves the symlink to its real target FIRST -- without
# this, running the script via the /usr/local/bin symlink (exactly what
# the setup above creates) makes BASH_SOURCE point at the symlink's own
# location, not the real project directory, and main.py isn't there.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

if [ -f "$SCRIPT_DIR/venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/venv/bin/python"
else
    PYTHON="python3"
fi

cd "$SCRIPT_DIR" && exec "$PYTHON" main.py "$@"
