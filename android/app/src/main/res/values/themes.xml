<resources>
    <!-- Theme.MaterialComponents (no "DayNight") is the always-dark
         variant: deliberate here, not following system light/dark,
         since a white light-mode screen around the dark hologram
         widget would look broken rather than themed. -->
    <style name="Theme.Gremlin" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/gremlin_accent</item>
        <item name="colorPrimaryDark">@color/gremlin_bg</item>
        <item name="colorAccent">@color/gremlin_accent</item>
        <item name="android:windowBackground">@color/gremlin_bg</item>
        <item name="android:textColorPrimary">@color/gremlin_text_primary</item>
        <item name="android:textColorSecondary">@color/gremlin_text_secondary</item>
        <item name="android:textColorHint">@color/gremlin_text_secondary</item>
        <item name="colorSurface">@color/gremlin_surface</item>
        <item name="colorOnSurface">@color/gremlin_text_primary</item>
    </style>
</resources>
