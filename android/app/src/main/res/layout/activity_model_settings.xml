<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/model_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/model_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:alpha="0.85"
            android:text="Loading..."
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin token"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Same token as Settings → Admin. Needed to save any edit below."
            android:textSize="11sp"
            android:alpha="0.7"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/model_admin_token_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Admin token"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fields"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:id="@+id/model_fields_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/model_status_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:alpha="0.8" />

    </LinearLayout>
</ScrollView>
