<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gremlin"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/settings_connection_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:alpha="0.7"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="At home"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/settings_persona_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:text="Loading..." />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registered models"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/settings_models_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/settings_repair_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pair / re-pair with a desktop"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Away from home"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Used automatically whenever the desktop isn't reachable. Keys stay only on this phone, sent straight to Anthropic/Google, never through the desktop."
            android:textSize="11sp"
            android:alpha="0.7"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anthropic (Claude) API key"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/anthropic_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:inputType="textPassword"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/claude_model_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gemini API key"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/gemini_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AIza..."
            android:inputType="textPassword"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/gemini_model_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/preferred_provider_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/prefer_claude_radio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prefer Claude" />

            <RadioButton
                android:id="@+id/prefer_gemini_radio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prefer Gemini"
                android:layout_marginStart="16dp" />
        </RadioGroup>

        <Button
            android:id="@+id/save_keys_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Separate from the connection above on purpose -- this token isn't in the pairing QR code, so pairing for chat alone never grants this. Runs whatever you type on the desktop directly. Only enter this if you set it up yourself via `gremlin admin-token`."
            android:textSize="11sp"
            android:alpha="0.7"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/admin_token_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Admin token"
            android:inputType="textPassword"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/admin_command_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Command to run on the desktop, e.g. docker compose restart jellyfin"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/admin_run_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Run on Desktop"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/admin_result_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/admin_reboot_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reboot Desktop"
            android:backgroundTint="#8B2020" />

    </LinearLayout>
</ScrollView>
